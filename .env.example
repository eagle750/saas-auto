# ─── Required for build ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AI-Auto-SaaS"

# ─── Auth (required for login/signup) ────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # Generate with: openssl rand -base64 32

# ─── Database ─────────────────────────────────────────────────────────────────
# Vercel: add DATABASE_URL for Production *and* Preview (not only “Build”).
# Neon: prefer the pooled connection string (host contains “-pooler”) for serverless.
# prisma.config.ts uses DIRECT_DATABASE_URL for migrations when set, else DATABASE_URL.
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── OAuth providers (optional - login still works via credentials) ──────────
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ─── Stripe (optional - needed for payments) ─────────────────────────────────
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_STARTER_PRICE_ID=""
# STRIPE_PRO_PRICE_ID=""
# STRIPE_ENTERPRISE_PRICE_ID=""

# ─── AI Models (optional - needed for AI features) ──────────────────────────
# ANTHROPIC_API_KEY=""
# GOOGLE_GENERATIVE_AI_API_KEY=""

# ─── Security (optional - needed for encryption features) ───────────────────
# Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=""
