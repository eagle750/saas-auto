# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.

# ============================================
# DATABASE — Neon Postgres
# Get from: neon.tech → Dashboard → Connection Details
# ============================================
DATABASE_URL=postgresql://user:pass@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# ============================================
# AUTH — NextAuth.js
# Generate secret: openssl rand -base64 32
# ============================================
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URI must include: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# STORAGE — Cloudflare R2
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
# ============================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=resume-ai-uploads
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ============================================
# AI — Anthropic Claude
# Get from: console.anthropic.com → API Keys
# ============================================
ANTHROPIC_API_KEY=

# ============================================
# PAYMENTS — Razorpay (India)
# Get from: dashboard.razorpay.com → Settings → API Keys
# NEXT_PUBLIC_ prefix is intentional — used in client-side Razorpay checkout
# ============================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# ============================================
# EMAIL — Resend
# Get from: resend.com → API Keys
# ============================================
RESEND_API_KEY=

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ResumeAI
