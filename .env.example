# ─── Required for build ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AI-Auto-SaaS"

# ─── Auth (required for login/signup) ────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # Generate with: openssl rand -base64 32

# ─── Database (optional for static pages) ────────────────────────────────────
# DATABASE_URL="postgresql://user:pass@localhost:5432/ai_auto_saas"
# DIRECT_DATABASE_URL="postgresql://user:pass@localhost:5432/ai_auto_saas"

# ─── OAuth providers (optional - login still works via credentials) ──────────
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ─── Stripe (optional - needed for payments) ─────────────────────────────────
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_STARTER_PRICE_ID=""
# STRIPE_PRO_PRICE_ID=""
# STRIPE_ENTERPRISE_PRICE_ID=""

# ─── AI Models (optional - needed for AI features) ──────────────────────────
# ANTHROPIC_API_KEY=""
# GOOGLE_GENERATIVE_AI_API_KEY=""

# ─── Redis (optional - needed for background jobs) ──────────────────────────
# REDIS_URL="redis://localhost:6379"

# ─── Security (optional - needed for encryption features) ───────────────────
# Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=""
