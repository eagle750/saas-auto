generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  subscription  Subscription?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id])
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  plan                 Plan      @default(FREE)
  status               String    @default("active")
  currentPeriodEnd     DateTime?
  generationsUsed      Int       @default(0)
  generationsLimit     Int       @default(2)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

model Project {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  name           String
  requirement    String        @db.Text
  tier           ProjectTier
  status         ProjectStatus @default(DRAFT)
  config         Json
  githubRepo     String?
  githubPat      String?
  architecture   Json?
  generatedFiles Json?
  buildLogs      BuildLog[]
  errorLog       String?       @db.Text
  deploymentUrl  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum ProjectTier {
  STATIC
  DYNAMIC
  FULLSTACK
}

enum ProjectStatus {
  DRAFT
  QUEUED
  PLANNING
  GENERATING
  REVIEWING
  PUSHING
  DEPLOYING
  COMPLETED
  FAILED
}

model BuildLog {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  step      String
  message   String
  level     LogLevel @default(INFO)
  metadata  Json?
  createdAt DateTime @default(now())
}

enum LogLevel {
  INFO
  WARN
  ERROR
  SUCCESS
}
